package loop;
import java.util.*;
public class pratice{
    public static void main(String[]args){
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int copy=n;
        int temp=0;
        int rev=0;
        while(n!=0){
            temp= n%10;
            rev=rev*10+temp;
            n=n/10;
        }
    if(rev==copy){
        System.out.println("Palindrome");
    }
    else{
        System.out.println("Not Palindrome");
    }
}
}
